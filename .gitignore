# ══════════════════════════════════════════════════════════════════════════════
# R STANDARD ARTIFACTS
# ══════════════════════════════════════════════════════════════════════════════

# History files
.Rhistory
.Rapp.history

# Session data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# Produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# Translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# ══════════════════════════════════════════════════════════════════════════════
# CONFIDENTIAL RAW DATA
# ══════════════════════════════════════════════════════════════════════════════

# Telemetry data (Lilly et al., unpublished)
R/00_raw_data/telemetry/*.csv

# Always publish example files regardless of the rules above
!R/00_raw_data/**/*_EXAMPLE.csv
!R/00_raw_data/**/*_EXAMPLE.xlsx

# Derived datasets — ignored by default (generated from confidential raw data)
R/00_derived_data/*.fst
R/00_derived_data/*.csv

# Exception: example versions are always published
!R/00_derived_data/*_EXAMPLE.fst
!R/00_derived_data/*_EXAMPLE.csv

# ══════════════════════════════════════════════════════════════════════════════
# LARGE GEOSPATIAL FILES
# ══════════════════════════════════════════════════════════════════════════════
*.nc
*.tif
*.tiff
*.gdb/
*.shp
*.dbf
*.shx
*.prj
*.sbn
*.sbx
*.cpg

# ══════════════════════════════════════════════════════════════════════════════
# R BINARY DATA FORMATS
# ══════════════════════════════════════════════════════════════════════════════

# Ignore all .fst and .rds by default
*.fst
*.RDS
*.rds

# Exception: derived datasets shared for reproducibility
!data/derived/*.fst

# ══════════════════════════════════════════════════════════════════════════════
# INTERMEDIATE DATA (regenerable by running the scripts)
# ══════════════════════════════════════════════════════════════════════════════
data/intermediate/

# ══════════════════════════════════════════════════════════════════════════════
# SYSTEM FILES
# ══════════════════════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini